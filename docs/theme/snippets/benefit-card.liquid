{% comment %}
  Benefit Card Snippet
  Usage: {% render 'benefit-card', icon: 'strength', title: 'Boost Strength', text: '...', delay: '1' %}
{% endcomment %}

<div class="benefit-card glass-card reveal stagger-{{ delay }}">
  <div class="benefit-card__icon icon-{{ icon }}" aria-hidden="true">
    {% case icon %}
      {% when 'strength' %}
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="18" width="6" height="12" rx="1"/>
          <rect x="38" y="18" width="6" height="12" rx="1"/>
          <rect x="12" y="14" width="6" height="20" rx="1"/>
          <rect x="30" y="14" width="6" height="20" rx="1"/>
          <line x1="18" y1="24" x2="30" y2="24"/>
        </svg>
      {% when 'muscle' %}
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 38 C10 28 18 20 24 14"/>
          <path d="M24 14 C30 20 38 28 38 38"/>
          <path d="M16 34 L24 24 L32 34"/>
          <circle cx="24" cy="10" r="4"/>
        </svg>
      {% when 'energy' %}
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="20 4 8 28 22 28 18 44 40 18 26 18 30 4"/>
        </svg>
      {% when 'brain' %}
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 44V28"/>
          <path d="M16 12a8 8 0 0 1 16 0c0 4-4 6-4 10h-8c0-4-4-6-4-10z"/>
          <line x1="18" y1="28" x2="30" y2="28"/>
          <line x1="20" y1="32" x2="28" y2="32"/>
          <line x1="22" y1="36" x2="26" y2="36"/>
        </svg>
      {% else %}
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="24" cy="24" r="18"/></svg>
    {% endcase %}
  </div>
  <h3 class="benefit-card__title">{{ title }}</h3>
  <p class="benefit-card__text">{{ text }}</p>
</div>
