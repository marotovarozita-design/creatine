{% comment %}
  FAQ Item Snippet
  Usage: {% render 'faq-item', question: '...', answer: '...', index: 1 %}
{% endcomment %}

<div class="faq-item reveal stagger-{{ index }}" data-faq>
  <button class="faq-item__question" aria-expanded="false" aria-controls="faqAnswer{{ index }}">
    <span>{{ question }}</span>
    <svg class="faq-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
  </button>
  <div class="faq-item__answer" id="faqAnswer{{ index }}" role="region">
    <div class="faq-item__answer-inner">
      <p>{{ answer }}</p>
    </div>
  </div>
</div>
